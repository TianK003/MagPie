# Public, client-safe values only (shipped in the app bundle). NEVER put
# server-only provider keys here (ELEVENLABS/OPENAI/SERVICE_ROLE live as
# Supabase function secrets + EAS secrets, never in the client).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key
EXPO_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
